{
  "framework": "vite",
  "buildCommand": "npm run render-build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "nodeVersion": "22.x",
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
