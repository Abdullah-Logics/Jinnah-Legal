# ── Jinnah Legal Backend Environment ─────────────────────────
# Copy this file to .env and fill in your values.

PORT=3001

# ── REQUIRED: JWT Secret ────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ── Frontend URL (for CORS) ─────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Node Environment ───────────────────────────────────────
NODE_ENV=development

# ── AI (Google Gemini — FREE) ───────────────────────────────
# Get free key at: https://aistudio.google.com/apikey (no credit card)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Database (MSSQL) ─────────────────────────────────────────
# Required for production. Leave blank to use SQLite.
#
# MSSQL_SERVER=localhost
# MSSQL_DATABASE=JinnahLegal
# MSSQL_USER=sa
# MSSQL_PASSWORD=
# MSSQL_PORT=1433
# MSSQL_ENCRYPT=false
# MSSQL_TRUST_CERT=true
