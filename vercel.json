{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "jinnah-legal": {
      "type": "web",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm run render-build"
    }
  }
}
